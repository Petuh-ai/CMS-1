# ============================================
# Переменные окружения для Render
# ============================================

# Приложение
APP_DEBUG=false
APP_TIMEZONE=UTC
LOG_LEVEL=info

# База данных
# Для MySQL на Render используйте значения из Render Dashboard
DB_DRIVER=mysql
DB_HOST=your-database-host
DB_PORT=3306
DB_NAME=cms_bd
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# Сессия
SESSION_SECURE=true
